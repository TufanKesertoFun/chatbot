NODE_ENV=production
PORT=3001

# Set this to your public domain(s), comma-separated
CORS_ORIGIN=https://staychatty.com,https://www.staychatty.com

# In Docker network, DB host is `db`
DATABASE_URL=postgresql://postgres:change_me_strong_db_password@db:5432/ovobot?schema=public

JWT_SECRET=replace_with_a_long_random_secret

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe12345!

# Required for bot response generation
GEMINI_API_KEY=replace_me

# Optional
GOOGLE_TRANSLATE_API_KEY=
GOOGLE_PROJECT_ID=
